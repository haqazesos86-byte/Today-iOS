# Fastfile — Today iOS App
# Auto-generated by setup. Run `bundle exec fastlane ios beta` to upload to TestFlight
# or `bundle exec fastlane ios release` to submit to App Store.

default_platform(:ios)

platform :ios do

  before_all do
    setup_ci if ENV['CI']
  end

  # ============================================================
  # 1. BUILD — Create an unsigned archive (use for inspection)
  # ============================================================
  desc "Build an unsigned archive for inspection"
  lane :build_unsigned do
    gym(
      project: "Today.xcodeproj",
      scheme: "Today",
      configuration: "Release",
      sdk: "iphoneos",
      output_directory: "./build",
      output_name: "Today.ipa",
      export_method: "development",
      export_options: {
        signingStyle: "manual",
        stripSwiftSymbols: true
      },
      skip_codesigning: true,
      skip_package_pkg: true,
      clean: true
    )
  end

  # ============================================================
  # 2. BETA — Upload to TestFlight
  # ============================================================
  desc "Upload build to TestFlight (internal testing)"
  lane :beta do
    # Pre-flight: verify required env vars
    UI.user_error!("APPLE_TEAM_ID not set") unless ENV['APPLE_TEAM_ID']
    UI.user_error!("APPLE_KEY_ID not set") unless ENV['APPLE_KEY_ID']
    UI.user_error!("APPLE_KEY_CONTENT not set") unless ENV['APPLE_KEY_CONTENT']
    UI.user_error!("APPLE_KEY_ISSUER_ID not set") unless ENV['APPLE_KEY_ISSUER_ID']

    # Decode the API key
    api_key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_KEY_ID']}.p8")
    unless File.exist?(api_key_path)
      require 'base64'
      FileUtils.mkdir_p(File.dirname(api_key_path))
      File.open(api_key_path, 'wb') do |file|
        file.write(Base64.decode64(ENV['APPLE_KEY_CONTENT']))
      end
    end

    api_key = app_store_connect_api_key(
      key_id: ENV['APPLE_KEY_ID'],
      issuer_id: ENV['APPLE_KEY_ISSUER_ID'],
      key_filepath: api_key_path,
      in_house: false
    )

    # Build
    gym(
      project: "Today.xcodeproj",
      scheme: "Today",
      configuration: "Release",
      sdk: "iphoneos",
      output_directory: "./build",
      output_name: "Today.ipa",
      export_method: "app-store",
      clean: true
    )

    # Upload
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )

    UI.success("✅ Build uploaded to TestFlight!")
  end

  # ============================================================
  # 3. RELEASE — Submit to App Store
  # ============================================================
  desc "Submit build to App Store for review"
  lane :release do
    # Same as beta, but with upload_to_app_store
    api_key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_KEY_ID']}.p8")
    require 'base64'
    FileUtils.mkdir_p(File.dirname(api_key_path))
    File.open(api_key_path, 'wb') do |file|
      file.write(Base64.decode64(ENV['APPLE_KEY_CONTENT']))
    end

    api_key = app_store_connect_api_key(
      key_id: ENV['APPLE_KEY_ID'],
      issuer_id: ENV['APPLE_KEY_ISSUER_ID'],
      key_filepath: api_key_path,
      in_house: false
    )

    gym(
      project: "Today.xcodeproj",
      scheme: "Today",
      configuration: "Release",
      sdk: "iphoneos",
      output_directory: "./build",
      output_name: "Today.ipa",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      force: true,
      skip_screenshots: false,
      skip_metadata: false,
      submit_for_review: true,
      automatic_release: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )

    UI.success("✅ Submitted to App Store review!")
  end

  # ============================================================
  # 4. SCREENSHOTS — Capture from simulator (CI)
  # ============================================================
  desc "Capture App Store screenshots from simulator"
  lane :screenshots do
    capture_ios_screenshots(
      project: "Today.xcodeproj",
      scheme: "Today",
      output_directory: "./screenshots",
      clear_previous_screenshots: true,
      devices: [
        "iPhone 16 Pro Max (6.7-inch)",
        "iPhone 8 Plus (5.5-inch)"
      ],
      languages: ["zh-Hans"],
      launch_arguments: ["SEED_SAMPLE_DATA=1"]
    )
  end

  # ============================================================
  # 5. METADATA — Sync App Store metadata from files
  # ============================================================
  desc "Sync App Store metadata from ./metadata directory"
  lane :metadata do
    deliver(
      api_key_path: ENV['APPLE_KEY_PATH'] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_KEY_ID']}.p8"),
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      metadata_path: "./metadata",
      app_identifier: "com.today.app",
      username: ENV['APPLE_TEAM_ID']
    )
  end

end
